{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["node", "vite/client", "pinia"],
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "include": [
    "store/**/*",
    "*.vue",
    "*.ts",
    "login/signup.vue",
    "login/login.vue",
    "login/index.vue",
    "vue/**/*",
    "chat/xStream.vue",
    "chat/ChatList.vue",
    "chat/ChatFrame.vue",
    "chat/ChatBox.vue"
  ],
  "exclude": ["node_modules", "dist"]
}
